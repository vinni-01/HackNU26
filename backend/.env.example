APP_NAME="AI Brainstorm Canvas"
ENVIRONMENT="development"
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# SQLite for local dev; use postgresql://user:pass@host/db for production
DATABASE_URL=sqlite:///./app.db

REDIS_URL=redis://localhost:6379

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-live-001

HIGGSFIELD_API_KEY=your-higgsfield-api-key
HIGGSFIELD_BASE_URL=https://api.higgsfield.ai/v1

R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=brainstorm-assets
R2_PUBLIC_BASE=https://pub-<hash>.r2.dev/brainstorm-assets

CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
VECTORIZE_INDEX=spatial-rag-index

# WebSocket URL of the Cloudflare Worker that bridges the tldraw DO to this server
CF_SYNC_WS_URL=wss://your-worker.workers.dev/sync
# Shared secret used to validate HMAC webhook signatures (leave empty in dev)
CF_WEBHOOK_SECRET=

API_BASE_URL=http://localhost:8000
